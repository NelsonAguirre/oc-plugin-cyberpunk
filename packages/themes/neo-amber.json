{
  "$schema": "https://opencode.ai/theme.json",
  "name": "neo-amber",
  "defs": {
    "amber": "#FFB000",
    "amberBright": "#FFC107",
    "amberDim": "#B87333",
    "amberDark": "#8B4513",
    "amberFaint": "#654321",
    "amberMuted": "#CD853F",
    "amberOrange": "#FF8C00",
    "coral": "#FF6B35",
    "gold": "#FFD700",
    "oliveLight": "#BADA55",
    "ivory": "#FFFACD",
    "burntOrange": "#E65100",
    "crtBlack": "#0A0500",
    "crtPanel": "#1A0F00",
    "crtElement": "#241800",
    "crtBorder": "#3D280A"
  },
  "theme": {
    "primary": {
      "dark": "amber",
      "light": "amber"
    },
    "secondary": {
      "dark": "gold",
      "light": "gold"
    },
    "accent": {
      "dark": "coral",
      "light": "coral"
    },
    "error": {
      "dark": "coral",
      "light": "coral"
    },
    "warning": {
      "dark": "amberOrange",
      "light": "amberOrange"
    },
    "success": {
      "dark": "oliveLight",
      "light": "oliveLight"
    },
    "info": {
      "dark": "gold",
      "light": "gold"
    },
    "text": {
      "dark": "amber",
      "light": "amber"
    },
    "textMuted": {
      "dark": "amberDim",
      "light": "amberDim"
    },
    "background": {
      "dark": "crtBlack",
      "light": "crtBlack"
    },
    "backgroundPanel": {
      "dark": "crtPanel",
      "light": "crtPanel"
    },
    "backgroundElement": {
      "dark": "crtElement",
      "light": "crtElement"
    },
    "backgroundMenu": {
      "dark": "crtElement",
      "light": "crtElement"
    },
    "selectedListItemText": {
      "dark": "crtBlack",
      "light": "crtBlack"
    },
    "border": {
      "dark": "crtBorder",
      "light": "crtBorder"
    },
    "borderActive": {
      "dark": "amber",
      "light": "amber"
    },
    "borderSubtle": {
      "dark": "crtElement",
      "light": "crtElement"
    },
    "diffAdded": {
      "dark": "oliveLight",
      "light": "oliveLight"
    },
    "diffRemoved": {
      "dark": "coral",
      "light": "coral"
    },
    "diffContext": {
      "dark": "amberDark",
      "light": "amberDark"
    },
    "diffHunkHeader": {
      "dark": "amberMuted",
      "light": "amberMuted"
    },
    "diffHighlightAdded": {
      "dark": "oliveLight",
      "light": "oliveLight"
    },
    "diffHighlightRemoved": {
      "dark": "coral",
      "light": "coral"
    },
    "diffAddedBg": {
      "dark": "#1A1A05",
      "light": "#1A1A05"
    },
    "diffRemovedBg": {
      "dark": "#1A0A05",
      "light": "#1A0A05"
    },
    "diffContextBg": {
      "dark": "crtPanel",
      "light": "crtPanel"
    },
    "diffLineNumber": {
      "dark": "amberFaint",
      "light": "amberFaint"
    },
    "diffAddedLineNumberBg": {
      "dark": "#0F0F03",
      "light": "#0F0F03"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#0F0803",
      "light": "#0F0803"
    },
    "markdownText": {
      "dark": "amber",
      "light": "amber"
    },
    "markdownHeading": {
      "dark": "gold",
      "light": "gold"
    },
    "markdownLink": {
      "dark": "coral",
      "light": "coral"
    },
    "markdownLinkText": {
      "dark": "coral",
      "light": "coral"
    },
    "markdownCode": {
      "dark": "oliveLight",
      "light": "oliveLight"
    },
    "markdownBlockQuote": {
      "dark": "amberDim",
      "light": "amberDim"
    },
    "markdownEmph": {
      "dark": "coral",
      "light": "coral"
    },
    "markdownStrong": {
      "dark": "gold",
      "light": "gold"
    },
    "markdownHorizontalRule": {
      "dark": "amberDark",
      "light": "amberDark"
    },
    "markdownListItem": {
      "dark": "amber",
      "light": "amber"
    },
    "markdownListEnumeration": {
      "dark": "amberDim",
      "light": "amberDim"
    },
    "markdownImage": {
      "dark": "coral",
      "light": "coral"
    },
    "markdownImageText": {
      "dark": "coral",
      "light": "coral"
    },
    "markdownCodeBlock": {
      "dark": "oliveLight",
      "light": "oliveLight"
    },
    "syntaxComment": {
      "dark": "amberDark",
      "light": "amberDark"
    },
    "syntaxKeyword": {
      "dark": "coral",
      "light": "coral"
    },
    "syntaxFunction": {
      "dark": "gold",
      "light": "gold"
    },
    "syntaxVariable": {
      "dark": "amber",
      "light": "amber"
    },
    "syntaxString": {
      "dark": "oliveLight",
      "light": "oliveLight"
    },
    "syntaxNumber": {
      "dark": "ivory",
      "light": "ivory"
    },
    "syntaxType": {
      "dark": "burntOrange",
      "light": "burntOrange"
    },
    "syntaxOperator": {
      "dark": "amberMuted",
      "light": "amberMuted"
    },
    "syntaxPunctuation": {
      "dark": "amberDark",
      "light": "amberDark"
    }
  }
}