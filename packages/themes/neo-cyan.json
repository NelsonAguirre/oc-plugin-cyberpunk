{
  "$schema": "https://opencode.ai/theme.json",
  "name": "neo-cyan",
  "defs": {
    "cyan": "#00F0FF",
    "cyanBright": "#00FFFF",
    "cyanDim": "#00A0B0",
    "cyanDark": "#007A8A",
    "cyanFaint": "#004A5A",
    "cyanMuted": "#008899",
    "electricBlue": "#3B82F6",
    "electricBlueSoft": "#60A5FA",
    "mint": "#2DD4BF",
    "tealDeep": "#14B8A6",
    "magenta": "#D946EF",
    "deepBlue": "#001a1f",
    "panelBlue": "#002028",
    "elementBlue": "#003038",
    "borderBlue": "#004050"
  },
  "theme": {
    "primary": {
      "dark": "cyan",
      "light": "cyan"
    },
    "secondary": {
      "dark": "mint",
      "light": "mint"
    },
    "accent": {
      "dark": "magenta",
      "light": "magenta"
    },
    "error": {
      "dark": "magenta",
      "light": "magenta"
    },
    "warning": {
      "dark": "electricBlueSoft",
      "light": "electricBlueSoft"
    },
    "success": {
      "dark": "mint",
      "light": "mint"
    },
    "info": {
      "dark": "electricBlue",
      "light": "electricBlue"
    },
    "text": {
      "dark": "cyan",
      "light": "cyan"
    },
    "textMuted": {
      "dark": "cyanDim",
      "light": "cyanDim"
    },
    "background": {
      "dark": "deepBlue",
      "light": "deepBlue"
    },
    "backgroundPanel": {
      "dark": "panelBlue",
      "light": "panelBlue"
    },
    "backgroundElement": {
      "dark": "elementBlue",
      "light": "elementBlue"
    },
    "backgroundMenu": {
      "dark": "elementBlue",
      "light": "elementBlue"
    },
    "selectedListItemText": {
      "dark": "deepBlue",
      "light": "deepBlue"
    },
    "border": {
      "dark": "borderBlue",
      "light": "borderBlue"
    },
    "borderActive": {
      "dark": "cyan",
      "light": "cyan"
    },
    "borderSubtle": {
      "dark": "elementBlue",
      "light": "elementBlue"
    },
    "diffAdded": {
      "dark": "mint",
      "light": "mint"
    },
    "diffRemoved": {
      "dark": "magenta",
      "light": "magenta"
    },
    "diffContext": {
      "dark": "cyanDark",
      "light": "cyanDark"
    },
    "diffHunkHeader": {
      "dark": "cyanMuted",
      "light": "cyanMuted"
    },
    "diffHighlightAdded": {
      "dark": "mint",
      "light": "mint"
    },
    "diffHighlightRemoved": {
      "dark": "magenta",
      "light": "magenta"
    },
    "diffAddedBg": {
      "dark": "#001820",
      "light": "#001820"
    },
    "diffRemovedBg": {
      "dark": "#18001A",
      "light": "#18001A"
    },
    "diffContextBg": {
      "dark": "panelBlue",
      "light": "panelBlue"
    },
    "diffLineNumber": {
      "dark": "cyanFaint",
      "light": "cyanFaint"
    },
    "diffAddedLineNumberBg": {
      "dark": "#001A18",
      "light": "#001A18"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#0F0010",
      "light": "#0F0010"
    },
    "markdownText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownHeading": {
      "dark": "electricBlueSoft",
      "light": "electricBlueSoft"
    },
    "markdownLink": {
      "dark": "magenta",
      "light": "magenta"
    },
    "markdownLinkText": {
      "dark": "magenta",
      "light": "magenta"
    },
    "markdownCode": {
      "dark": "magenta",
      "light": "magenta"
    },
    "markdownBlockQuote": {
      "dark": "cyanDim",
      "light": "cyanDim"
    },
    "markdownEmph": {
      "dark": "mint",
      "light": "mint"
    },
    "markdownStrong": {
      "dark": "magenta",
      "light": "magenta"
    },
    "markdownHorizontalRule": {
      "dark": "cyanDark",
      "light": "cyanDark"
    },
    "markdownListItem": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownListEnumeration": {
      "dark": "cyanDim",
      "light": "cyanDim"
    },
    "markdownImage": {
      "dark": "mint",
      "light": "mint"
    },
    "markdownImageText": {
      "dark": "mint",
      "light": "mint"
    },
    "markdownCodeBlock": {
      "dark": "magenta",
      "light": "magenta"
    },
    "syntaxComment": {
      "dark": "cyanDark",
      "light": "cyanDark"
    },
    "syntaxKeyword": {
      "dark": "electricBlue",
      "light": "electricBlue"
    },
    "syntaxFunction": {
      "dark": "mint",
      "light": "mint"
    },
    "syntaxVariable": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxString": {
      "dark": "magenta",
      "light": "magenta"
    },
    "syntaxNumber": {
      "dark": "electricBlueSoft",
      "light": "electricBlueSoft"
    },
    "syntaxType": {
      "dark": "tealDeep",
      "light": "tealDeep"
    },
    "syntaxOperator": {
      "dark": "cyanMuted",
      "light": "cyanMuted"
    },
    "syntaxPunctuation": {
      "dark": "cyanDark",
      "light": "cyanDark"
    }
  }
}