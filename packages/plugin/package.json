{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@nelsonaguirre/oc-plugin-neo-terminal",
  "version": "1.0.1",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NelsonAguirre/oc-neo-terminal.git"
  },
  "exports": {
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "scanlines": true,
        "scanline_speed": 0.008,
        "vignette": 0.65,
        "sidebar": true
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.14"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "oxfmt": "0.41.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
