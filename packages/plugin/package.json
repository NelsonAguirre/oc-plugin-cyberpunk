{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "oc-plugin-cyberpunk",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NelsonAguirre/oc-plugin-cyberpunk.git"
  },
  "exports": {
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "scanlines": true,
        "scanline_speed": 0.008,
        "vignette": 0.65,
        "sidebar": true
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.14"
  },
  "devDependencies": {
    "oxfmt": "0.41.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
